Rule 9     compound_statement -> BEGIN statement_list END
Rule 10    statement_list -> statement_list SEMICOLON statement
Rule 11    statement_list -> statement
Rule 12    statement -> assignment
Rule 13    statement -> if_statement
Rule 14    statement -> while_statement
Rule 15    statement -> for_statement
Rule 16    statement -> repeat_statement
Rule 17    statement -> compound_statement
Rule 18    statement -> empty
Rule 19    assignment -> ID ASSIGN expression
Rule 20    if_statement -> IF condition THEN statement
Rule 21    if_statement -> IF condition THEN statement ELSE statement
Rule 22    while_statement -> WHILE condition DO statement
Rule 23    for_statement -> FOR assignment TO expression DO statement
Rule 24    repeat_statement -> REPEAT statement_list UNTIL condition
Rule 25    condition -> expression LESS expression
Rule 26    condition -> expression GREATER expression
Rule 27    condition -> expression EQUAL expression
Rule 28    condition -> expression LESSEQUAL expression
Rule 29    condition -> expression GREATEREQUAL expression
Rule 30    condition -> expression DISTINT expression
Rule 31    expression -> expression PLUS term
Rule 32    expression -> expression MINUS term
Rule 33    expression -> term
Rule 34    term -> term TIMES factor
Rule 35    term -> term DIVIDE factor
Rule 36    term -> factor
Rule 37    factor -> NUMBER
Rule 38    factor -> ID
Rule 39    factor -> LPAREN expression RPAREN
Rule 40    empty -> <empty>

