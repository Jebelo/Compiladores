Grammar

Rule 0     S' -> program
Rule 1     program -> PROGRAM ID SEMICOLON declarations compound_statement DOT
Rule 2     declarations -> VAR var_decl_list
Rule 3     declarations -> empty
Rule 4     var_decl_list -> var_decl_list var_decl
Rule 5     var_decl_list -> var_decl
Rule 6     var_decl -> id_list COLON ID SEMICOLON
Rule 7     id_list -> id_list COMMA ID
Rule 8     id_list -> ID
Rule 9     declarations -> subprogram_decl_list
Rule 10    subprogram_decl_list -> subprogram_decl_list subprogram_decl
Rule 11    subprogram_decl_list -> subprogram_decl
Rule 12    subprogram_decl -> FUNCTION ID LPAREN param_list RPAREN COLON ID SEMICOLON local_declarations compound_statement SEMICOLON
Rule 13    subprogram_decl -> PROCEDURE ID LPAREN param_list RPAREN SEMICOLON local_declarations compound_statement SEMICOLON
Rule 14    subprogram_open -> FUNCTION ID
Rule 15    subprogram_open -> PROCEDURE ID
Rule 16    param_list -> param_list SEMICOLON param
Rule 17    param_list -> param
Rule 18    param_list -> empty
Rule 19    param -> id_list COLON ID
Rule 20    local_declarations -> VAR var_decl_list
Rule 21    local_declarations -> empty
Rule 22    compound_statement -> BEGIN statement_list END
Rule 23    statement_list -> statement_list SEMICOLON statement
Rule 24    statement_list -> statement
Rule 25    statement -> assignment
Rule 26    statement -> if_statement
Rule 27    statement -> while_statement
Rule 28    statement -> for_statement
Rule 29    statement -> repeat_statement
Rule 30    statement -> compound_statement
Rule 31    statement -> empty
Rule 32    assignment -> ID ASSIGN expression
Rule 33    if_statement -> IF condition THEN statement
Rule 34    if_statement -> IF condition THEN statement ELSE statement
Rule 35    while_statement -> WHILE condition DO statement
Rule 36    for_statement -> FOR assignment TO expression DO statement
Rule 37    repeat_statement -> REPEAT statement_list UNTIL condition
Rule 38    condition -> expression LESS expression
Rule 39    condition -> expression GREATER expression
Rule 40    condition -> expression EQUAL expression
Rule 41    condition -> expression LESSEQUAL expression
Rule 42    condition -> expression GREATEREQUAL expression
Rule 43    condition -> expression DISTINT expression
Rule 44    expression -> expression PLUS term
Rule 45    expression -> expression MINUS term
Rule 46    expression -> term
Rule 47    term -> term TIMES factor
Rule 48    term -> term DIVIDE factor
Rule 49    term -> factor
Rule 50    factor -> NUMBER
Rule 51    factor -> ID
Rule 52    factor -> LPAREN expression RPAREN
Rule 53    empty -> <empty>

